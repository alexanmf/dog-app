# ---------------------------------------
# Python bytecode / caches
# ---------------------------------------
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/

# ---------------------------------------
# Virtual environments
# ---------------------------------------
.venv/
venv/
env/

# ---------------------------------------
# Local databases / state
# ---------------------------------------
*.sqlite
*.sqlite3
*.db
*.db-journal
dogs.db
instance/

# ---------------------------------------
# Environment / secrets (DO NOT COMMIT)
# ---------------------------------------
.env
*.env
.env.*
.envrc

# ---------------------------------------
# Logs / coverage / reports
# ---------------------------------------
logs/
*.log
coverage/
.coverage
.coverage.*
htmlcov/

# ---------------------------------------
# Build / packaging artifacts
# ---------------------------------------
dist/
build/
.eggs/
*.egg-info/
.cache/
pip-wheel-metadata/

# ---------------------------------------
# Uploads & generated media
# (Do NOT store user uploads in Git)
# ---------------------------------------
uploads/
media/
user_uploads/
static/uploads/

# Keep folder structure (optional)
!uploads/.gitkeep
!media/.gitkeep
!user_uploads/.gitkeep
!static/uploads/.gitkeep

# ---------------------------------------
# Node / frontend (future-proofing)
# ---------------------------------------
node_modules/
npm-debug.log*
yarn*.log
pnpm-*.log
.eslintcache
.next/
.svelte-kit/
*.map

# ---------------------------------------
# OS / Editors
# ---------------------------------------
.DS_Store
Thumbs.db
.idea/
.vscode/

# ---------------------------------------
# Flask / runtime
# ---------------------------------------
flask_session/
*.pid
tmp/

# ---------------------------------------
# Docker / deployment (optional)
# ---------------------------------------
*.pid.lock
