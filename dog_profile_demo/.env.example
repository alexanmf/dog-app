# -----------------------------
# Flask Application Settings
# -----------------------------
FLASK_ENV=development
SECRET_KEY=CHANGE_ME_STRONG_SECRET
PORT=5000

# -----------------------------
# Database Configuration
# -----------------------------
# Local (SQLite fallback)
# Leave DATABASE_URL empty to use SQLite (configured in app.py)
DATABASE_URL=

# Example PostgreSQL (Render / production)
# postgres://username:password@host:5432/dbname
# DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DATABASE_NAME

# -----------------------------
# Cloudinary Configuration (for file storage)
# -----------------------------
# Recommended: single URL
CLOUDINARY_URL=cloudinary://API_KEY:API_SECRET@CLOUD_NAME

# Optional separate values (if not using URL)
CLOUDINARY_CLOUD_NAME=CHANGE_ME
CLOUDINARY_API_KEY=CHANGE_ME
CLOUDINARY_API_SECRET=CHANGE_ME

# Folder organization
CLOUDINARY_FOLDER=dogs/images
CLOUDINARY_DOC_FOLDER=dogs/documents

# -----------------------------
# Upload & File Limits
# -----------------------------
# Max upload size (10MB)
MAX_CONTENT_LENGTH=10485760

# Allowed file types (frontend + validation)
ALLOWED_FILE_TYPES=png,jpg,jpeg,gif,webp,pdf,doc,docx,xls,xlsx,csv,txt

# -----------------------------
# Session / Security
# -----------------------------
SESSION_COOKIE_HTTPONLY=True
SESSION_COOKIE_SAMESITE=Lax

# Set to True only in production with HTTPS
SESSION_COOKIE_SECURE=False

# -----------------------------
# Optional Email / Notifications
# -----------------------------
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=CHANGE_ME
MAIL_PASSWORD=CHANGE_ME
MAIL_DEFAULT_SENDER=CHANGE_ME

# -----------------------------
# Optional Debug Flags
# -----------------------------
# Turn off in production
DEBUG=True


